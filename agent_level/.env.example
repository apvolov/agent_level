# Скопируй этот файл в .env и при необходимости отредактируй

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tiles
MINIO_SECURE=false

# При интеграции с реальным транспортным уровнем — замени адрес
TRANSPORT_URL=http://localhost:8001

SEGMENT_SIZE_BYTES=3145728
